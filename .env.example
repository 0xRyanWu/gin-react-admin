# =============================================================================
# 後台管理系統模板 - 環境變數設定範例
# 使用方式：複製此檔案為 .env，並填入實際值
# cp .env.example .env
# =============================================================================

# --- PostgreSQL 資料庫設定 ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=admindb
POSTGRES_PORT=5432

# --- 後端 Go 應用程式設定 ---

# 後端監聽埠
PORT=8080

# PostgreSQL DSN（資料庫連線字串）
# 格式：host=<host> user=<user> password=<password> dbname=<db> port=<port> sslmode=disable TimeZone=Asia/Taipei
DB_DSN=host=localhost user=admin password=change_me_in_production dbname=admindb port=5432 sslmode=disable TimeZone=Asia/Taipei

# JWT 簽名密鑰（請使用強隨機字串，長度建議 ≥ 32 字元）
# 生成範例：openssl rand -hex 32
JWT_SECRET=please_change_this_to_a_strong_random_secret_key_min_32_chars

# JWT Token 有效期（小時）
JWT_EXPIRE_HOURS=24

# --- 前端設定（在 frontend/.env 中設定）---
# VITE_API_BASE_URL=http://localhost:8080

# --- Redis 設定（asynq 任務佇列使用）---
# 格式：host:port
REDIS_ADDR=localhost:6379
